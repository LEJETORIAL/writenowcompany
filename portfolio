const cur=document.getElementById('cur'),cRing=document.getElementById('curRing');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;cur.style.transform=`translate(${mx}px,${my}px) translate(-50%,-50%)`;});
(function tick(){rx+=(mx-rx)*.12;ry+=(my-ry)*.12;cRing.style.transform=`translate(${rx}px,${ry}px) translate(-50%,-50%)`;requestAnimationFrame(tick);})();
document.addEventListener('mouseover',e=>{const t=e.target.closest('a,button,.wk-item,.col-post,.f-btn,.wk-add-btn,.btn-primary,.wk-play-btn');if(t){cur.classList.add('h');cRing.classList.add('h');}else{cur.classList.remove('h');cRing.classList.remove('h');}});
