<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>WRITE NOW COMPANY</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Mono:wght@400;700&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{--lime:#C8F400;--black:#0A0A0A;--bg:#E8E4DC;--white:#FAFAF7;--gray:#9A9690;--dark:#111110;--dark2:#1A1A18;--red:#D13B2A}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--black);font-family:'DM Sans',sans-serif;overflow-x:hidden;cursor:none}
.cur{width:10px;height:10px;background:var(--black);border-radius:50%;position:fixed;top:0;left:0;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);transition:width .15s,height .15s,background .15s}
.cur-ring{width:34px;height:34px;border:1.5px solid var(--black);border-radius:50%;position:fixed;top:0;left:0;pointer-events:none;z-index:9998;transform:translate(-50%,-50%)}
.cur.h{width:6px;height:6px;background:var(--lime)}
.cur-ring.h{border-color:var(--lime)}
nav{position:fixed;top:0;left:0;right:0;z-index:300;display:flex;align-items:center;justify-content:space-between;padding:22px 40px;border-bottom:1.5px solid var(--black);background:var(--bg)}
.nav-logo{font-family:'Bebas Neue',sans-serif;font-size:18px;letter-spacing:3px;color:var(--black);text-decoration:none}
.nav-links{display:flex;gap:36px;list-style:none}
.nav-links a{font-family:'Space Mono',monospace;font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--black);text-decoration:none;transition:opacity .2s}
.nav-links a:hover,.nav-links a.active{opacity:.4}
.nav-cta{background:var(--lime);color:var(--black);border:1.5px solid var(--black);font-family:'Space Mono',monospace;font-size:11px;letter-spacing:2px;text-transform:uppercase;padding:11px 22px;text-decoration:none;display:inline-flex;align-items:center;gap:8px;transition:background .2s,color .2s}
.nav-cta:hover{background:var(--black);color:var(--lime)}
.page{display:none;padding-top:69px;min-height:100vh}
.page.active{display:block}
/* HOME */
#page-home{min-height:100vh;display:flex;flex-direction:column;justify-content:flex-end;padding:120px 40px 60px;position:relative;overflow:hidden;padding-top:0!important}
.hero-tag{font-family:'Space Mono',monospace;font-size:11px;letter-spacing:3px;color:var(--gray);margin-bottom:24px;opacity:0;animation:fadeUp .7s .3s forwards}
.hero-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(80px,13vw,200px);line-height:.88;letter-spacing:-1px;color:var(--black);opacity:0;animation:fadeUp .8s .5s forwards}
.hero-title .lime-wrap{display:inline-block;position:relative}
.hero-title .lime-wrap .lime-bg{position:absolute;inset:0;background:var(--dark);z-index:-1;transform:scaleX(0);transform-origin:left;transition:transform .5s ease}
.hero-title:hover .lime-wrap .lime-bg{transform:scaleX(1)}
.hero-title .accent{color:var(--lime);position:relative;z-index:1}
.hero-bottom{display:flex;align-items:flex-end;justify-content:space-between;margin-top:48px;padding-top:28px;border-top:1px solid rgba(10,10,10,.18);opacity:0;animation:fadeUp .8s .7s forwards}
.hero-desc{max-width:360px;font-size:14px;line-height:1.8;color:#555;font-style:italic}
.hero-scroll{display:flex;align-items:center;gap:12px;font-family:'Space Mono',monospace;font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--gray)}
.scroll-line{width:56px;height:1px;background:var(--gray);animation:scLine 2s infinite ease-in-out}
@keyframes scLine{0%,100%{transform:scaleX(1);opacity:1}50%{transform:scaleX(.3);opacity:.3}}
@keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
.marquee-wrap{background:var(--dark);padding:17px 0;overflow:hidden;border-top:1.5px solid var(--black);border-bottom:1.5px solid var(--black)}
.marquee-track{display:flex;width:max-content;animation:marquee 18s linear infinite}
.marquee-item{font-family:'Bebas Neue',sans-serif;font-size:21px;letter-spacing:4px;color:var(--bg);padding:0 28px;white-space:nowrap}
.marquee-item .ms{color:var(--lime);margin:0 6px}
@keyframes marquee{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
/* ABOUT */
#page-about{background:var(--dark);color:var(--white);padding-top:69px}
.about-hero{padding:80px 40px 60px}
.about-kicker{font-family:'Space Mono',monospace;font-size:11px;letter-spacing:3px;color:var(--lime);text-transform:uppercase;margin-bottom:24px}
.about-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(64px,10vw,150px);line-height:.88;letter-spacing:-1px;color:var(--white)}
.about-title .accent{color:var(--lime)}
.ab-block{min-height:70vh;position:relative}
.ab-block.txt-only{display:flex;align-items:center;padding:80px 40px}
.ab-block.img-right{display:grid;grid-template-columns:1fr 1fr}
.ab-block.img-left{display:grid;grid-template-columns:1fr 1fr}
.ab-block.img-full{min-height:75vh}
.ab-block.img-trio{display:grid;grid-template-columns:1fr 1fr 1fr;min-height:55vh}
.ab-block.dark{background:var(--dark)}
.ab-block.dark2{background:var(--dark2)}
.ab-text{padding:80px 56px;display:flex;flex-direction:column;justify-content:center}
.ab-text .lbl{font-family:'Space Mono',monospace;font-size:10px;letter-spacing:3px;color:var(--lime);text-transform:uppercase;margin-bottom:18px}
.ab-text h3{font-family:'Bebas Neue',sans-serif;font-size:clamp(32px,4vw,60px);line-height:.95;margin-bottom:24px;color:var(--white)}
.ab-text h3 .a{color:var(--lime)}
.ab-text p{font-family:'Space Mono',monospace;font-size:12px;line-height:2;color:rgba(250,250,247,.5);max-width:420px}
.ab-img{position:relative;overflow:hidden;background:var(--dark2);display:flex;align-items:stretch}
.ab-img .ph{width:100%;min-height:400px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;border:1px dashed rgba(200,244,0,.15)}
.ab-img .ph-icon{width:44px;height:44px;border:1.5px solid rgba(200,244,0,.25);border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--lime);font-size:22px;opacity:.5}
.ab-img .ph-lbl{font-family:'Space Mono',monospace;font-size:10px;letter-spacing:2.5px;text-transform:uppercase;color:rgba(200,244,0,.35);text-align:center}
.ab-img input[type=file]{position:absolute;inset:0;opacity:0;cursor:pointer;z-index:5}
.ab-img .preview{position:absolute;inset:0;background-size:cover;background-position:center;transition:transform .7s ease}
.ab-block:hover .preview{transform:scale(1.04)}
.ab-stats{display:grid;grid-template-columns:repeat(3,1fr);border-top:1.5px solid rgba(250,250,247,.06);border-bottom:1.5px solid rgba(250,250,247,.06);background:var(--dark)}
.ab-stat{padding:56px 40px;border-right:1.5px solid rgba(250,250,247,.06)}
.ab-stat:last-child{border-right:none}
.ab-stat-n{font-family:'Bebas Neue',sans-serif;font-size:80px;line-height:1;color:var(--lime);letter-spacing:-2px}
.ab-stat-l{font-family:'Space Mono',monospace;font-size:10px;letter-spacing:3px;text-transform:uppercase;color:var(--gray);margin-top:6px}
/* SERVICES */
#page-services{background:var(--bg)}
.srv-hero{padding:80px 40px 56px;border-bottom:1.5px solid var(--black)}
.srv-hero h2{font-family:'Bebas Neue',sans-serif;font-size:clamp(64px,10vw,140px);line-height:.88;letter-spacing:-1px}
.srv-hero h2 .accent{color:var(--lime);background:var(--dark);padding:0 8px;display:inline-block}
.srv-intro{margin-top:28px;max-width:520px;font-size:14px;line-height:1.85;color:#555}
.srv-row{display:grid;grid-template-columns:72px 1fr 1fr auto;align-items:start;gap:36px;padding:44px 40px;border-bottom:1.5px solid rgba(10,10,10,.1);transition:background .25s}
.srv-row:hover{background:rgba(200,244,0,.07)}
.srv-n{font-family:'Space Mono',monospace;font-size:11px;letter-spacing:2px;color:var(--lime);padding-top:4px}
.srv-name{font-family:'Bebas Neue',sans-serif;font-size:clamp(28px,3vw,48px);line-height:.95;letter-spacing:-.5px}
.srv-desc{font-family:'Space Mono',monospace;font-size:12px;line-height:2;color:#666;padding-top:5px}
.srv-chips{display:flex;flex-direction:column;gap:6px;align-items:flex-end;padding-top:5px}
.srv-chip{font-family:'Space Mono',monospace;font-size:9px;letter-spacing:1.5px;text-transform:uppercase;border:1.5px solid rgba(10,10,10,.18);padding:4px 12px;color:#666}
.srv-cta{background:var(--dark);padding:80px 40px;display:flex;align-items:center;justify-content:space-between}
.srv-cta h3{font-family:'Bebas Neue',sans-serif;font-size:clamp(36px,5vw,80px);line-height:.92;letter-spacing:-1px;color:var(--white)}
.srv-cta h3 .accent{color:var(--lime)}
.btn-primary{background:var(--lime);color:var(--black);border:1.5px solid var(--lime);font-family:'Space Mono',monospace;font-size:11px;letter-spacing:2.5px;text-transform:uppercase;padding:16px 32px;cursor:none;text-decoration:none;display:inline-block;transition:background .2s,color .2s,border-color .2s;white-space:nowrap}
.btn-primary:hover{background:var(--white);border-color:var(--white)}
/* WORK */
#page-work,#page-column{background:var(--bg)}
.wk-header{padding:64px 40px 40px;display:flex;align-items:flex-end;justify-content:space-between;border-bottom:1.5px solid var(--black)}
.wk-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(64px,10vw,140px);line-height:.88;letter-spacing:-1px}
.wk-count{font-family:'Space Mono',monospace;font-size:12px;letter-spacing:2px;color:var(--gray)}
.filter-bar{padding:20px 40px;display:flex;gap:8px;flex-wrap:wrap;border-bottom:1.5px solid rgba(10,10,10,.08)}
.f-btn{font-family:'Space Mono',monospace;font-size:10px;letter-spacing:2px;text-transform:uppercase;padding:8px 18px;border:1.5px solid rgba(10,10,10,.2);background:transparent;color:var(--gray);cursor:none;transition:all .2s}
.f-btn.active,.f-btn:hover{background:var(--black);color:var(--white);border-color:var(--black)}
.wk-grid{padding:36px 40px 80px;display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.wk-item{cursor:none}
.wk-thumb-wrap{overflow:hidden;position:relative;background:var(--dark)}
.wk-item[data-orient="vertical"] .wk-thumb-wrap{aspect-ratio:9/16}
.wk-item[data-orient="horizontal"] .wk-thumb-wrap{aspect-ratio:16/9}
.wk-thumb{width:100%;height:100%;object-fit:cover;display:block;transition:transform .65s cubic-bezier(.25,.46,.45,.94)}
.wk-item:hover .wk-thumb{transform:scale(1.06)}
.wk-ph{width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-family:'Bebas Neue',sans-serif;font-size:11px;letter-spacing:4px;color:rgba(255,255,255,.1);text-transform:uppercase}
.wk-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(10,10,10,.85) 0%,transparent 55%);opacity:0;transition:opacity .35s;display:flex;flex-direction:column;justify-content:flex-end;padding:20px}
.wk-item:hover .wk-overlay{opacity:1}
.wk-ov-title{font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:.5px;color:var(--white);margin-bottom:4px}
.wk-ov-cat{font-family:'Space Mono',monospace;font-size:9px;letter-spacing:2.5px;text-transform:uppercase;color:var(--lime)}
.wk-play-btn{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%) scale(0);width:52px;height:52px;background:rgba(200,244,0,.15);backdrop-filter:blur(8px);border:1.5px solid rgba(200,244,0,.4);border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--lime);transition:transform .3s ease,background .2s}
.wk-item:hover .wk-play-btn{transform:translate(-50%,-50%) scale(1)}
.wk-item:hover .wk-play-btn:hover{background:var(--lime);color:var(--black)}
.play-icon{width:14px;height:14px;fill:currentColor;margin-left:2px}
.wk-meta{padding:12px 0 0}
.wk-meta-title{font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:.3px;margin-bottom:3px}
.wk-meta-cat{font-family:'Space Mono',monospace;font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--gray)}
.wk-add-btn{display:flex;align-items:center;gap:10px;font-family:'Space Mono',monospace;font-size:10px;letter-spacing:2px;text-transform:uppercase;background:none;border:1.5px dashed rgba(10,10,10,.22);color:var(--gray);cursor:none;padding:14px 26px;transition:border-color .2s,color .2s;margin:0 40px 40px}
.wk-add-btn:hover{border-color:var(--lime);color:var(--black)}
/* COLUMN */
.col-header{padding:64px 40px 40px;border-bottom:1.5px solid var(--black);display:flex;align-items:flex-end;justify-content:space-between}
.col-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(64px,10vw,140px);line-height:.88;letter-spacing:-1px}
.col-list{padding:0 40px 80px}
.col-post{display:grid;grid-template-columns:1fr 1fr;gap:56px;padding:60px 0;border-bottom:1.5px solid rgba(10,10,10,.1);position:relative;align-items:start}
.col-post.no-img{grid-template-columns:1fr}
.post-img-wrap{overflow:hidden;aspect-ratio:4/3;background:var(--dark)}
.post-img-wrap img{width:100%;height:100%;object-fit:cover;transition:transform .65s ease;display:block}
.col-post:hover .post-img-wrap img{transform:scale(1.04)}
.post-meta{display:flex;gap:14px;align-items:center;margin-bottom:16px}
.post-cat{font-family:'Space Mono',monospace;font-size:9px;letter-spacing:3px;text-transform:uppercase;background:var(--lime);color:var(--black);padding:3px 10px}
.post-date{font-family:'Space Mono',monospace;font-size:9px;letter-spacing:2px;color:var(--gray)}
.post-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(28px,3.5vw,52px);line-height:.95;letter-spacing:-.5px;margin-bottom:18px;cursor:none;transition:color .25s}
.col-post:hover .post-title{color:var(--gray)}
.post-excerpt{font-family:'Space Mono',monospace;font-size:12px;line-height:2;color:#666;margin-bottom:22px;display:-webkit-box;-webkit-line-clamp:4;-webkit-box-orient:vertical;overflow:hidden}
.post-more{font-family:'Space Mono',monospace;font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--black);text-decoration:none;display:inline-flex;align-items:center;gap:8px;border-bottom:1.5px solid var(--black);padding-bottom:2px;transition:color .2s,border-color .2s;cursor:none}
.post-more:hover{color:var(--gray);border-color:var(--gray)}
.post-actions{position:absolute;top:60px;right:0;display:flex;gap:8px;opacity:0;transition:opacity .2s}
.col-post:hover .post-actions{opacity:1}
.p-btn{font-family:'Space Mono',monospace;font-size:9px;letter-spacing:1.5px;text-transform:uppercase;background:none;border:1.5px solid rgba(10,10,10,.18);color:var(--gray);padding:5px 13px;cursor:none;transition:all .2s}
.p-btn:hover{border-color:var(--black);color:var(--black)}
.p-btn.del:hover{border-color:var(--red);color:var(--red)}
/* MODALS */
.modal-bd{position:fixed;inset:0;background:rgba(10,10,10,.94);z-index:500;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .3s;padding:40px}
.modal-bd.open{opacity:1;pointer-events:all}
.modal-box{background:var(--dark);max-width:960px;width:100%;max-height:88vh;overflow-y:auto;transform:translateY(24px);transition:transform .4s cubic-bezier(.25,.46,.45,.94);scrollbar-width:none;position:relative}
.modal-bd.open .modal-box{transform:translateY(0)}
.m-close{position:sticky;top:0;float:right;width:44px;height:44px;background:var(--black);border:none;color:var(--white);font-size:14px;cursor:none;display:flex;align-items:center;justify-content:center;z-index:10;transition:background .2s,color .2s}
.m-close:hover{background:var(--lime);color:var(--black)}
.m-video{background:#000;aspect-ratio:16/9;position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center}
.m-video video,.m-video iframe{width:100%;height:100%;object-fit:cover;border:none}
.m-video-ph{width:100%;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;cursor:pointer}
.m-video-ph:hover .play-circle{background:var(--lime);border-color:var(--lime)}
.play-circle{width:72px;height:72px;border:2px solid rgba(200,244,0,.3);border-radius:50%;display:flex;align-items:center;justify-content:center;transition:background .2s,border-color .2s}
.m-info{padding:36px 40px 44px;color:var(--white)}
.m-cat{font-family:'Space Mono',monospace;font-size:10px;letter-spacing:3px;text-transform:uppercase;color:var(--lime);margin-bottom:10px}
.m-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(28px,4vw,56px);letter-spacing:-.5px;line-height:1;margin-bottom:20px}
.m-desc{font-family:'Space Mono',monospace;font-size:12px;line-height:2;color:rgba(250,250,247,.55);margin-bottom:24px}
.m-chips{display:flex;flex-wrap:wrap;gap:8px}
.m-chip{font-family:'Space Mono',monospace;font-size:9px;letter-spacing:2px;text-transform:uppercase;border:1.5px solid rgba(255,255,255,.12);color:rgba(255,255,255,.4);padding:4px 13px}
.contact-bd{position:fixed;inset:0;background:rgba(10,10,10,.97);z-index:600;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .3s}
.contact-bd.open{opacity:1;pointer-events:all}
.contact-box{max-width:600px;width:90%;padding:64px;transform:translateY(20px);transition:transform .4s cubic-bezier(.25,.46,.45,.94);position:relative}
.contact-bd.open .contact-box{transform:translateY(0)}
.c-close{position:absolute;top:0;right:0;width:44px;height:44px;background:var(--dark2);border:none;color:var(--white);font-size:14px;cursor:none;display:flex;align-items:center;justify-content:center;transition:background .2s}
.c-close:hover{background:var(--lime);color:var(--black)}
.c-kicker{font-family:'Space Mono',monospace;font-size:10px;letter-spacing:3.5px;text-transform:uppercase;color:var(--lime);margin-bottom:18px}
.c-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(48px,7vw,96px);line-height:.88;letter-spacing:-1px;color:var(--white);margin-bottom:44px}
.c-title .accent{color:var(--lime)}
.fg{margin-bottom:24px}
.fg label{display:block;font-family:'Space Mono',monospace;font-size:10px;letter-spacing:2.5px;text-transform:uppercase;color:var(--gray);margin-bottom:8px}
.fg input,.fg textarea{width:100%;background:none;border:none;border-bottom:1.5px solid rgba(255,255,255,.15);color:var(--white);font-family:'DM Sans',sans-serif;font-size:16px;padding:10px 0;outline:none;resize:none;transition:border-color .2s}
.fg input:focus,.fg textarea:focus{border-bottom-color:var(--lime)}
.fg textarea{min-height:90px}
.c-submit{width:100%;background:var(--lime);border:none;color:var(--black);font-family:'Space Mono',monospace;font-size:11px;letter-spacing:3px;text-transform:uppercase;padding:18px;cursor:none;transition:background .2s;margin-top:4px}
.c-submit:hover{background:var(--white)}
.c-success{display:none;text-align:center;padding:40px 0;font-family:'Bebas Neue',sans-serif;font-size:36px;color:var(--lime);letter-spacing:2px}
.editor-bd{position:fixed;inset:0;background:rgba(10,10,10,.96);z-index:700;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .3s;padding:24px}
.editor-bd.open{opacity:1;pointer-events:all}
.editor-box{background:var(--bg);max-width:720px;width:100%;max-height:90vh;overflow-y:auto;padding:48px;position:relative;transform:scale(.97);transition:transform .3s ease;scrollbar-width:none}
.editor-bd.open .editor-box{transform:scale(1)}
.e-close{position:absolute;top:16px;right:16px;width:36px;height:36px;background:var(--black);border:none;color:var(--white);cursor:none;display:flex;align-items:center;justify-content:center;font-size:13px;transition:background .2s}
.e-close:hover{background:var(--red)}
.e-title{font-family:'Bebas Neue',sans-serif;font-size:36px;letter-spacing:.5px;margin-bottom:28px}
.ef{margin-bottom:22px}
.ef label{display:block;font-family:'Space Mono',monospace;font-size:9px;letter-spacing:2.5px;text-transform:uppercase;color:var(--gray);margin-bottom:7px}
.ef input,.ef textarea,.ef select{width:100%;padding:11px 14px;border:1.5px solid rgba(10,10,10,.14);background:#fff;font-family:'DM Sans',sans-serif;font-size:14px;outline:none;resize:vertical;transition:border-color .2s;color:var(--black)}
.ef input:focus,.ef textarea:focus{border-color:var(--black)}
.ef textarea{min-height:140px}
.ef select{cursor:none;appearance:none}
.e-img-preview{width:100%;aspect-ratio:4/3;background:var(--dark);border:1.5px dashed rgba(10,10,10,.15);display:flex;align-items:center;justify-content:center;overflow:hidden;position:relative;cursor:pointer}
.e-img-preview img{width:100%;height:100%;object-fit:cover;display:none}
.e-img-lbl{font-family:'Space Mono',monospace;font-size:10px;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.25);pointer-events:none}
.e-img-preview input[type=file]{position:absolute;inset:0;opacity:0;cursor:pointer}
.e-actions{display:flex;gap:10px;margin-top:4px}
