document.getElementById('srvContactBtn').addEventListener('click',e=>{e.preventDefault();openModal('contactModal');});
function loadAboutImg(input,id){if(!input.files[0])return;const r=new FileReader();r.onload=e=>{const w=document.getElementById(id);w.querySelector('.ph').style.display='none';let p=w.querySelector('.preview');if(!p){p=document.createElement('div');p.className='preview';w.insertBefore(p,w.querySelector('input'));}p.style.backgroundImage=`url(${e.target.result})`;};r.readAsDataURL(input.files[0]);}
const catGrad={branded:'linear-gradient(135deg,#1c1917,#44403c)',interview:'linear-gradient(135deg,#0c1a2e,#1e3a5f)',editorial:'linear-gradient(135deg,#1a0a0a,#3a1c1c)',advertorial:'linear-gradient(135deg,#0a1a0a,#1c3a1c)'};
const catLabel={branded:'Branded Video',interview:'Interview',editorial:'Editorial',advertorial:'Advertorial'};
let works=[{id:1,title:'브랜드 필름 — 오설록',cat:'branded',orient:'horizontal',thumb:'',videoUrl:'',desc:'제주 감귤과 차의 이야기를 담은 브랜드 필름.',tags:['브랜딩','영상','2024']},{id:2,title:'CEO 인터뷰 시리즈',cat:'interview',orient:'vertical',thumb:'',videoUrl:'',desc:'국내 스타트업 창업자 10인 인터뷰 시리즈.',tags:['인터뷰','숏폼']},{id:3,title:'매거진 에디토리얼',cat:'editorial',orient:'horizontal',thumb:'',videoUrl:'',desc:'패션 브랜드 협업 에디토리얼.',tags:['에디토리얼','패션']},{id:4,title:'뷰티 애드버토리얼',cat:'advertorial',orient:'vertical',thumb:'',videoUrl:'',desc:'럭셔리 스킨케어 브랜드 애드버토리얼.',tags:['광고','뷰티']},{id:5,title:'라이프스타일 캠페인',cat:'branded',orient:'horizontal',thumb:'',videoUrl:'',desc:'홈 리빙 브랜드 봄 시즌 캠페인.',tags:['캠페인','2024']},{id:6,title:'아티스트 인터뷰',cat:'interview',orient:'vertical',thumb:'',videoUrl:'',desc:'국내 신진 작가와의 작업실 인터뷰.',tags:['아티스트']}];
let workNextId=7,workFilter='all',editWorkId=null,workImgData=null;
function renderWork(){const filtered=workFilter==='all'?works:works.filter(w=>w.cat===workFilter);document.getElementById('wkCount').textContent=`— ${String(filtered.length).padStart(2,'0')} PROJECTS`;const g=document.getElementById('wkGrid');g.innerHTML='';if(!filtered.length){g.innerHTML='<div class="empty-state" style="grid-column:1/-1"><p>아직 작업물이 없습니다</p></div>';return;}filtered.forEach(item=>{const d=document.createElement('div');d.className='wk-item';d.dataset.orient=item.orient;d.innerHTML=`<div class="wk-thumb-wrap">${item.thumb?`<img class="wk-thumb" src="${item.thumb}" alt="${item.title}">`:`<div class="wk-thumb wk-ph" style="background:${catGrad[item.cat]};width:100%;height:100%;">${catLabel[item.cat]}</div>`}<div class="wk-overlay"><div class="wk-ov-title">${item.title}</div><div class="wk-ov-cat">${catLabel[item.cat]}</div></div>${item.videoUrl?`<div class="wk-play-btn"><svg class="play-icon" viewBox="0 0 10 12"><polygon points="0,0 10,6 0,12"/></svg></div>`:''}</div><div class="wk-meta"><div class="wk-meta-title">${item.title}</div><div class="wk-meta-cat">${catLabel[item.cat]}</div></div>`;d.querySelector('.wk-thumb-wrap').addEventListener('click',()=>openWkModal(item));d.addEventListener('contextmenu',e=>{e.preventDefault();openWorkEditor(item.id);});g.appendChild(d);});}
function filterWork(f){workFilter=f;document.querySelectorAll('.f-btn').forEach(b=>b.classList.toggle('active',b.dataset.filter===f));renderWork();}
function openWkModal(item){document.getElementById('mCat').textContent=catLabel[item.cat];document.getElementById('mTitle').textContent=item.title;document.getElementById('mDesc').textContent=item.desc;document.getElementById('mChips').innerHTML=item.tags.map(t=>`<span class="m-chip">${t}</span>`).join('');const vw=document.getElementById('mVideoWrap');if(item.videoUrl)vw.innerHTML=`<iframe src="${item.videoUrl}" allowfullscreen></iframe>`;else if(item.thumb)vw.innerHTML=`<img src="${item.thumb}" style="width:100%;height:100%;object-fit:cover;">`;else vw.innerHTML=`<div style="background:${catGrad[item.cat]};width:100%;height:100%;display:flex;align-items:center;justify-content:center;"><div class="play-circle"><svg width="18" height="20" viewBox="0 0 10 12" fill="rgba(200,244,0,.4)"><polygon points="0,0 10,6 0,12"/></svg></div></div>`;openModal('wkModal');}
function openWorkEditor(id){editWorkId=id;workImgData=null;document.getElementById('eTitleWork').textContent=id?'EDIT WORK':'ADD WORK';if(id){const w=works.find(x=>x.id===id);document.getElementById('wTitle').value=w.title;document.getElementById('wCat').value=w.cat;document.getElementById('wOrient').value=w.orient;document.getElementById('wVideoUrl').value=w.videoUrl||'';document.getElementById('wDesc').value=w.desc;document.getElementById('wTags').value=w.tags.join(', ');const img=document.getElementById('workImgPrevImg');if(w.thumb){img.src=w.thumb;img.style.display='block';workImgData=w.thumb;}else img.style.display='none';}else{['wTitle','wVideoUrl','wDesc','wTags'].forEach(i=>document.getElementById(i).value='');document.getElementById('wCat').value='branded';document.getElementById('wOrient').value='horizontal';document.getElementById('workImgPrevImg').style.display='none';}openModal('workEditorBd');}
function prevWorkImg(input){if(!input.files[0])return;const r=new FileReader();r.onload=e=>{workImgData=e.target.result;const img=document.getElementById('workImgPrevImg');img.src=e.target.result;img.style.display='block';};r.readAsDataURL(input.files[0]);}
function saveWork(){const title=document.getElementById('wTitle').value.trim();if(!title){alert('제목을 입력해주세요.');return;}const item={id:editWorkId||workNextId++,title,cat:document.getElementById('wCat').value,orient:document.getElementById('wOrient').value,thumb:workImgData||'',videoUrl:document.getElementById('wVideoUrl').value.trim(),desc:document.getElementById('wDesc').value.trim(),tags:document.getElementById('wTags').value.split(',').map(t=>t.trim()).filter(Boolean)};if(editWorkId){const i=works.findIndex(w=>w.id===editWorkId);works[i]=item;}else works.unshift(item);closeModal('workEditorBd');renderWork();}
let posts=[{id:1,cat:'Essay',title:'좋은 인터뷰는 침묵으로 완성된다',date:'2026. 03. 15',excerpt:'촬영장에서 가장 오래 기억에 남는 순간은 말이 아닌 침묵에서 비롯됩니다. 질문이 끝나고 카메라가 돌아가는 사이, 사람들은 진짜 표정을 드러냅니다.',content:'촬영장에서 가장 오래 기억에 남는 순간은 말이 아닌 침묵에서 비롯됩니다.\n\n질문이 끝나고 카메라가 돌아가는 사이, 사람들은 진짜 표정을 드러냅니다. 그 틈을 잡아야 합니다.\n\n좋은 인터뷰 영상을 만들기 위해 가장 먼저 해야 할 일은 질문지를 완성하는 것이 아닙니다. 침묵을 허용하는 연습입니다.',img:'',hasImg:false},{id:2,cat:'Behind the Scenes',title:'겨울 제주, 오설록 촬영 비하인드',date:'2026. 02. 28',excerpt:'2월의 제주는 서울과 전혀 다른 시간을 갖고 있었습니다. 새벽 5시, 안개가 채 걷히지 않은 차밭에서 우리는 조명을 설치했습니다.',content:'2월의 제주는 서울과 전혀 다른 시간을 갖고 있었습니다.\n\n새벽 5시, 안개가 채 걷히지 않은 차밭에서 우리는 조명을 설치했습니다.\n\n촬영 감독이 말했습니다. "오늘 안개 운이 좋네요." 운이라고 불렀지만, 사실 그것은 며칠치 일기예보를 분석한 결과였습니다.',img:'',hasImg:false}];
let postNextId=3,editPostId=null,postImgData=null;
function renderPosts(){const list=document.getElementById('colList');list.innerHTML='';if(!posts.length){list.innerHTML='<div class="empty-state"><p>아직 작성된 글이 없습니다</p></div>';return;}posts.forEach(post=>{const d=document.createElement('div');d.className='col-post'+(post.hasImg?'':' no-img');d.innerHTML=`${post.hasImg?`<div class="post-img-wrap"><img src="${post.img}" alt="${post.title}" loading="lazy"></div>`:''}<div class="post-body"><div class="post-meta"><span class="post-cat">${post.cat}</span><span class="post-date">${post.date}</span></div><h3 class="post-title">${post.title}</h3><p class="post-excerpt">${post.excerpt}</p><a href="#" class="post-more" data-id="${post.id}">Read More →</a></div><div class="post-actions"><button class="p-btn" onclick="openPostEditor(${post.id})">Edit</button><button class="p-btn del" onclick="deletePost(${post.id})">Delete</button></div>`;d.querySelector('.post-more').addEventListener('click',e=>{e.preventDefault();openPostFull(post.id);});list.appendChild(d);});}
function openPostFull(id){const p=posts.find(x=>x.id===id);const vw=document.getElementById('mVideoWrap');if(p.hasImg&&p.img)vw.innerHTML=`<img src="${p.img}" style="width:100%;max-height:480px;object-fit:cover;display:block;">`;else vw.innerHTML=`<div style="background:var(--dark);padding:80px;display:flex;align-items:center;justify-content:center;aspect-ratio:16/9;"><span style="font-family:'Bebas Neue',sans-serif;font-size:80px;color:rgba(200,244,0,.1);letter-spacing:4px;">WRITE NOW</span></div>`;document.getElementById('mCat').textContent=p.cat+' · '+p.date;document.getElementById('mTitle').textContent=p.title;document.getElementById('mDesc').innerHTML=p.content.split('\n').filter(Boolean).map(x=>`<p style="margin-bottom:18px;">${x}</p>`).join('');document.getElementById('mChips').innerHTML='';openModal('wkModal');}
function openPostEditor(id){editPostId=id;postImgData=null;document.getElementById('eTitlePost').textContent=id?'EDIT POST':'NEW POST';if(id){const p=posts.find(x=>x.id===id);document.getElementById('pCat').value=p.cat;document.getElementById('pTitle').value=p.title;document.getElementById('pExcerpt').value=p.excerpt;document.getElementById('pContent').value=p.content;const img=document.getElementById('postImgPrevImg');if(p.hasImg&&p.img){img.src=p.img;img.style.display='block';postImgData=p.img;}else img.style.display='none';}else{['pTitle','pExcerpt','pContent'].forEach(i=>document.getElementById(i).value='');document.getElementById('pCat').value='Essay';document.getElementById('postImgPrevImg').style.display='none';}openModal('postEditorBd');}
function prevPostImg(input){if(!input.files[0])return;const r=new FileReader();r.onload=e=>{postImgData=e.target.result;const img=document.getElementById('postImgPrevImg');img.src=e.target.result;img.style.display='block';};r.readAsDataURL(input.files[0]);}
function savePost(){const title=document.getElementById('pTitle').value.trim();if(!title){alert('제목을 입력해주세요.');return;}const now=new Date();const ds=`${now.getFullYear()}. ${String(now.getMonth()+1).padStart(2,'0')}. ${String(now.getDate()).padStart(2,'0')}`;const post={id:editPostId||postNextId++,cat:document.getElementById('pCat').value,title,date:editPostId?posts.find(p=>p.id===editPostId).date:ds,excerpt:document.getElementById('pExcerpt').value.trim(),content:document.getElementById('pContent').value.trim(),img:postImgData||'',hasImg:!!postImgData};if(editPostId){const i=posts.findIndex(p=>p.id===editPostId);posts[i]=post;}else posts.unshift(post);closeModal('postEditorBd');renderPosts();}
function deletePost(id){if(!confirm('이 글을 삭제할까요?'))return;posts=posts.filter(p=>p.id!==id);renderPosts();}
function openModal(id){document.getElementById(id).classList.add('open');document.body.style.overflow='hidden';}
function closeModal(id){document.getElementById(id).classList.remove('open');document.body.style.overflow='';if(id==='wkModal')document.getElementById('mVideoWrap').innerHTML='';if(id==='contactModal'){document.getElementById('cSuccess').style.display='none';document.getElementById('cForm').style.display='block';}}
document.querySelectorAll('.modal-bd,.contact-bd,.editor-bd').forEach(el=>el.addEventListener('click',e=>{if(e.target===el)closeModal(el.id);}));
document.addEventListener('keydown',e=>{if(e.key==='Escape')['wkModal','contactModal','postEditorBd','workEditorBd'].forEach(closeModal);});
function submitContact(){const ins=document.querySelectorAll('#cForm input,#cForm textarea');let ok=true;ins.forEach(i=>{if(!i.value.trim())ok=false;});if(!ok){alert('모든 항목을 입력해주세요.');return;}document.getElementById('cForm').style.display='none';document.getElementById('cSuccess').style.display='block';}
renderWork();renderPosts();
</script>
</body>
</html>
